# Pinned build inputs for the wfb-ng CPE510 firmware. Sourced by build.sh.

# OpenWrt release + target. The patched mac80211/ath9k kmod source is vendored from this
# pinned release's SDK base feed at build time (docker/sdk-build.sh), so this single version
# pins both the userspace packages and the kernel-driver patch target.
OPENWRT_VERSION=25.12.4
OPENWRT_TARGET=ath79
OPENWRT_SUBTARGET=generic
OPENWRT_ARCH=mips_24kc

# wfb-ng source (user's fork; pushed before building)
WFB_REPO=https://github.com/svpcom/wfb-ng.git
WFB_COMMIT=ae6ce277ecb6321c332c8c51f37215bfa4c43c00
WFB_VERSION=2025.06.25

# CPE510 hardware revisions to build images for
CPE510_PROFILES="tplink_cpe510-v1 tplink_cpe510-v2 tplink_cpe510-v3 ubnt_rocket-m"
